  <button class="float-btn" title="Alerts">!</button>
  <button class="float-btn" title="Reports">R</button>
</div>

<script>
function updateIST() {
    const now = new Date();
    const parts = new Intl.DateTimeFormat('en-IN', {
        timeZone: 'Asia/Kolkata',
        year: 'numeric',
        month: 'short',
        day: '2-digit',
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit',
        hour12: true
    }).formatToParts(now);
    const dateParts = [];
    const timeParts = [];
    parts.forEach(part => {
        if (['day', 'month', 'year'].includes(part.type)) {
            dateParts.push(part.value);
        }
        if (['hour', 'minute', 'second', 'dayPeriod'].includes(part.type)) {
            timeParts.push(part.value);
        }
    });
    document.getElementById('dateDisplay').textContent = dateParts.join(' ');
    document.getElementById('timeDisplay').textContent = timeParts.join(' ');
}
updateIST();
setInterval(updateIST, 1000);

const progressRing = document.querySelector('.ring-progress');
const progressValue = 84;
const circumference = 2 * Math.PI * 88;
progressRing.style.strokeDasharray = circumference;
progressRing.style.strokeDashoffset = circumference;
setTimeout(() => {
    progressRing.style.strokeDashoffset = circumference - (progressValue / 100) * circumference;
}, 300);

const sparkline = document.getElementById('sparklineChart');
const ctx = sparkline.getContext('2d');
const dataPoints = [18, 27, 24, 31, 29, 41, 36, 44, 38, 48, 42, 50];

function drawChart() {
    const width = sparkline.clientWidth;
    const height = sparkline.clientHeight;
    sparkline.width = width * 2;
    sparkline.height = height * 2;
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(2, 2);
    ctx.clearRect(0, 0, width, height);
    ctx.lineWidth = 4;
    ctx.strokeStyle = '#8a5c2f';
    ctx.shadowColor = 'rgba(138, 92, 47, 0.28)';
    ctx.shadowBlur = 18;

    const max = Math.max(...dataPoints) + 10;
    const xStep = width / (dataPoints.length - 1);
    ctx.beginPath();
    dataPoints.forEach((value, index) => {
        const x = index * xStep;
        const y = height - (value / max) * (height - 32) - 16;
        if (index === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
    });
    ctx.stroke();

    dataPoints.forEach((value, index) => {
        const x = index * xStep;
        const y = height - (value / max) * (height - 32) - 16;
        ctx.beginPath();
        ctx.arc(x, y, 6, 0, Math.PI * 2);
        ctx.fillStyle = '#c38b55';
        ctx.fill();
    });
}

window.addEventListener('resize', drawChart);
drawChart();
</script>

